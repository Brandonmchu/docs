{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Every",
  "theme": "willow",
  "css": "custom.css",
  "colors": {
    "primary": "#0A0A0A",
    "light": "#0A0A0A",
    "dark": "#0A0A0A"
  },
  "font": {
    "family": "Inter",
    "weight": 400,
    "heading": {
      "family": "Inter",
      "weight": 600
    }
  },
  "background": {
    "color": {
      "light": "#FAFAFA",
      "dark": "#0A0A0A"
    }
  },
  "appearance": {
    "mode": "light"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "icons": {
    "library": "lucide"
  },
  "favicon": "/favicon.png",
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:type": "website",
      "og:site_name": "Every Documentation",
      "og:image": "https://every.ai/og-image.png",
      "twitter:card": "summary_large_image",
      "twitter:site": "@everyai"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart",
          "changelog"
        ]
      },
      {
        "group": "The AI Agent",
        "pages": [
          "ai/every-agent",
          "ai/voice-and-tone",
          "ai/business-context-and-tokens",
          "ai/scheduled-tasks",
          "ai/connect-ai-tools"
        ]
      },
      {
        "group": "Clients & Contacts",
        "pages": [
          "clients/clients",
          "clients/contacts",
          "clients/client-portal"
        ]
      },
      {
        "group": "Billing & Payments",
        "pages": [
          "billing/services-and-products",
          "billing/invoices-and-proposals",
          "billing/payments",
          "billing/expenses",
          "billing/recurring-billing"
        ]
      },
      {
        "group": "Scheduling & Time",
        "pages": [
          "scheduling/bookings",
          "scheduling/time-tracking"
        ]
      },
      {
        "group": "Integrations",
        "pages": [
          "integrations/stripe",
          "integrations/google-workspace",
          "integrations/xero",
          "integrations/hubspot",
          "integrations/granola"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/reports-and-export",
          "troubleshooting"
        ]
      }
    ]
  },
  "topbarLinks": [
    {
      "name": "Launch App",
      "url": "https://every.ai"
    },
    {
      "name": "Contact Support",
      "url": "mailto:hello@every.ai"
    }
  ],
  "logo": {
    "light": "/logo/every-logo-full.png",
    "dark": "/logo/every-logo-full.png",
    "href": "https://every.ai"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/everyai",
      "linkedin": "https://linkedin.com/company/every-ai"
    }
  },
  "redirects": [
    { "source": "/getting-started/organization-setup", "destination": "/quickstart" },
    { "source": "/getting-started/install-mobile-app", "destination": "/quickstart" },
    { "source": "/features/clients", "destination": "/clients/clients" },
    { "source": "/features/contacts", "destination": "/clients/contacts" },
    { "source": "/features/client-portal", "destination": "/clients/client-portal" },
    { "source": "/features/services", "destination": "/billing/services-and-products" },
    { "source": "/features/products", "destination": "/billing/services-and-products" },
    { "source": "/features/invoices", "destination": "/billing/invoices-and-proposals" },
    { "source": "/features/proposals", "destination": "/billing/invoices-and-proposals" },
    { "source": "/features/payments", "destination": "/billing/payments" },
    { "source": "/features/expenses", "destination": "/billing/expenses" },
    { "source": "/features/bookings", "destination": "/scheduling/bookings" },
    { "source": "/features/time-tracking", "destination": "/scheduling/time-tracking" },
    { "source": "/features/automations", "destination": "/billing/recurring-billing" },
    { "source": "/advanced/note-templates", "destination": "/billing/invoices-and-proposals" },
    { "source": "/advanced/multi-currency", "destination": "/billing/invoices-and-proposals" },
    { "source": "/advanced/tax-management", "destination": "/billing/invoices-and-proposals" },
    { "source": "/advanced/reporting", "destination": "/reference/reports-and-export" },
    { "source": "/data/csv-import", "destination": "/clients/contacts" },
    { "source": "/data/export", "destination": "/reference/reports-and-export" },
    { "source": "/ai/business-context", "destination": "/ai/business-context-and-tokens" },
    { "source": "/ai/tokens-and-usage", "destination": "/ai/business-context-and-tokens" },
    { "source": "/ai/undo-agent-actions", "destination": "/ai/every-agent" },
    { "source": "/ai/agent-scheduled-tasks", "destination": "/ai/scheduled-tasks" },
    { "source": "/integrations/every-mcp", "destination": "/ai/connect-ai-tools" },
    { "source": "/workflows/common-workflows", "destination": "/quickstart" },
    { "source": "/workflows/tips-for-success", "destination": "/quickstart" }
  ]
}
